<xml xmlns="https://developers.google.com/blockly/xml" is_dbot="true" collection="false">
  <variables>
    <variable id="stake_var">Stake</variable>
    <variable id="stake2_var">stake 2</variable>
    <variable id="text_var">text</variable>
    <variable id="text1_var">text1</variable>
    <variable id="text2_var">text2</variable>
    <variable id="tick_count_var">tick_count</variable>
    <variable id="loss_var">Loss</variable>
    <variable id="step_var">current_step</variable>
    <variable id="tp_var">Target Profit</variable>
    <variable id="entry_var">Entry Point Trigger</variable>
    <variable id="strategy_var">strategy_mode</variable>
    <variable id="text3_var">text3</variable>
    <variable id="avoid_var">bluebar digit to avoid (EVEN)</variable>
    <variable id="mart_var">product Martingale after loss</variable>
    <variable id="consecutive_var">consecutive_count</variable>
    <variable id="duration_var">Duration ticks</variable>
  </variables>

  <block type="trade_definition" id="trade_def_root" deletable="false" x="0" y="60">
    <statement name="TRADE_OPTIONS">
      <block type="trade_definition_market" id="td_market" deletable="false" movable="false">
        <field name="MARKET_LIST">synthetic_index</field>
        <field name="SUBMARKET_LIST">random_index</field>
        <field name="SYMBOL_LIST">R_75</field>
        <next>
          <block type="trade_definition_tradetype" id="td_tradetype" deletable="false" movable="false">
            <field name="TRADETYPECAT_LIST">digits</field>
            <field name="TRADETYPE_LIST">evenodd</field>
            <next>
              <block type="trade_definition_contracttype" id="td_contracttype" deletable="false" movable="false">
                <field name="TYPE_LIST">both</field>
                <next>
                  <block type="trade_definition_candleinterval" id="td_candle" deletable="false" movable="false">
                    <field name="CANDLEINTERVAL_LIST">60</field>
                    <next>
                      <block type="trade_definition_restartbuysell" id="td_restart_bs" deletable="false" movable="false">
                        <field name="TIME_MACHINE_ENABLED">FALSE</field>
                        <next>
                          <block type="trade_definition_restartonerror" id="td_restart_err" deletable="false" movable="false">
                            <field name="RESTARTONERROR">TRUE</field>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>

    <statement name="SUBMARKET">
      <block type="trade_definition_tradeoptions" id="td_tradeoptions">
        <mutation xmlns="http://www.w3.org/1999/xhtml" has_first_barrier="false" has_second_barrier="false" has_prediction="false"></mutation>
        <field name="DURATIONTYPE_LIST">t</field>
        <field name="CURRENCY_LIST">USD</field>
        <value name="DURATION">
          <shadow type="math_number" id="dur_shadow">
            <field name="NUM">1</field>
          </shadow>
          <block type="variables_get" id="dur_get">
            <field name="VAR" id="duration_var">Duration ticks</field>
          </block>
        </value>
        <value name="AMOUNT">
          <shadow type="math_number" id="amt_shadow">
            <field name="NUM">1</field>
          </shadow>
          <block type="variables_get" id="amt_get">
            <field name="VAR" id="stake_var">Stake</field>
          </block>
        </value>
      </block>
    </statement>

    <statement name="INITIALIZATION">
      <block type="variables_set" id="init_stake">
        <field name="VAR" id="stake_var">Stake</field>
        <value name="VALUE">
          <block type="math_number" id="init_stake_n"><field name="NUM">0.35</field></block>
        </value>
        <next>
          <block type="variables_set" id="init_stake2">
            <field name="VAR" id="stake2_var">stake 2</field>
            <value name="VALUE">
              <block type="math_number" id="init_stake2_n"><field name="NUM">0.35</field></block>
            </value>
            <next>
              <block type="variables_set" id="init_loss">
                <field name="VAR" id="loss_var">Loss</field>
                <value name="VALUE">
                  <block type="math_number" id="init_loss_n"><field name="NUM">1000</field></block>
                </value>
                <next>
                  <block type="variables_set" id="init_tp">
                    <field name="VAR" id="tp_var">Target Profit</field>
                    <value name="VALUE">
                      <block type="math_number" id="init_tp_n"><field name="NUM">2</field></block>
                    </value>
                    <next>
                      <block type="variables_set" id="init_entry">
                        <field name="VAR" id="entry_var">Entry Point Trigger</field>
                        <value name="VALUE">
                          <block type="math_number" id="init_entry_n"><field name="NUM">1</field></block>
                        </value>
                        <next>
                          <block type="variables_set" id="init_avoid">
                            <field name="VAR" id="avoid_var">bluebar digit to avoid (EVEN)</field>
                            <value name="VALUE">
                              <block type="math_number" id="init_avoid_n"><field name="NUM">2</field></block>
                            </value>
                            <next>
                              <block type="variables_set" id="init_dur">
                                <field name="VAR" id="duration_var">Duration ticks</field>
                                <value name="VALUE">
                                  <block type="math_number" id="init_dur_n"><field name="NUM">1</field></block>
                                </value>
                                <next>
                                  <block type="variables_set" id="init_mart">
                                    <field name="VAR" id="mart_var">product Martingale after loss</field>
                                    <value name="VALUE">
                                      <block type="math_number" id="init_mart_n"><field name="NUM">2</field></block>
                                    </value>
                                    <next>
                                      <block type="variables_set" id="init_step">
                                        <field name="VAR" id="step_var">current_step</field>
                                        <value name="VALUE">
                                          <block type="math_number" id="init_step_n"><field name="NUM">1</field></block>
                                        </value>
                                        <next>
                                          <block type="variables_set" id="init_strategy">
                                            <field name="VAR" id="strategy_var">strategy_mode</field>
                                            <value name="VALUE">
                                              <block type="text" id="init_strategy_t"><field name="TEXT">odd</field></block>
                                            </value>
                                          </block>
                                        </next>
                                      </block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
  </block>

  <block type="before_purchase" id="before_purchase_root" deletable="false" x="0" y="900">
    <statement name="BEFOREPURCHASE_STACK">
      <block type="controls_if" id="step_check">
        <mutation xmlns="http://www.w3.org/1999/xhtml" elseif="1" else="1"></mutation>
        <value name="IF0">
          <block type="logic_compare" id="is_step_1">
            <field name="OP">EQ</field>
            <value name="A">
              <block type="variables_get" id="get_step_1"><field name="VAR" id="step_var">current_step</field></block>
            </value>
            <value name="B">
              <block type="math_number" id="step_1_num"><field name="NUM">1</field></block>
            </value>
          </block>
        </value>
        <statement name="DO0">
          <block type="controls_if" id="check_prediction">
            <value name="IF0">
              <block type="logic_compare" id="match_prediction">
                <field name="OP">EQ</field>
                <value name="A">
                  <block type="last_digit" id="get_digit_step1"></block>
                </value>
                <value name="B">
                  <block type="variables_get" id="get_prediction"><field name="VAR" id="entry_var">Entry Point Trigger</field></block>
                </value>
              </block>
            </value>
            <statement name="DO0">
              <block type="controls_if" id="set_dynamic_strat">
                <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
                <value name="IF0">
                  <block type="math_number_property" id="pred_even_check">
                    <mutation xmlns="http://www.w3.org/1999/xhtml" divisor_input="false"></mutation>
                    <field name="PROPERTY">EVEN</field>
                    <value name="NUMBER_TO_CHECK">
                      <block type="variables_get" id="get_pred_val"><field name="VAR" id="entry_var">Entry Point Trigger</field></block>
                    </value>
                  </block>
                </value>
                <statement name="DO0">
                  <block type="variables_set" id="set_strat_odd_dyn">
                    <field name="VAR" id="strategy_var">strategy_mode</field>
                    <value name="VALUE">
                      <block type="text" id="txt_odd_dyn"><field name="TEXT">odd</field></block>
                    </value>
                  </block>
                </statement>
                <statement name="ELSE">
                  <block type="variables_set" id="set_strat_even_dyn">
                    <field name="VAR" id="strategy_var">strategy_mode</field>
                    <value name="VALUE">
                      <block type="text" id="txt_even_dyn"><field name="TEXT">even</field></block>
                    </value>
                  </block>
                </statement>
                <next>
                  <block type="variables_set" id="move_to_step2">
                    <field name="VAR" id="step_var">current_step</field>
                    <value name="VALUE">
                      <block type="math_number" id="step_2_set"><field name="NUM">2</field></block>
                    </value>
                    <next>
                      <block type="variables_set" id="init_tick_count">
                        <field name="VAR" id="tick_count_var">tick_count</field>
                        <value name="VALUE">
                          <block type="math_number" id="zero_tick"><field name="NUM">0</field></block>
                        </value>
                        <next>
                          <block type="variables_set" id="init_consecutive">
                            <field name="VAR" id="consecutive_var">consecutive_count</field>
                            <value name="VALUE">
                              <block type="math_number" id="zero_consecutive"><field name="NUM">0</field></block>
                            </value>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </statement>
          </block>
        </statement>

        <value name="IF1">
          <block type="logic_compare" id="is_step_2">
            <field name="OP">EQ</field>
            <value name="A">
              <block type="variables_get" id="get_step_2"><field name="VAR" id="step_var">current_step</field></block>
            </value>
            <value name="B">
              <block type="math_number" id="step_2_num"><field name="NUM">2</field></block>
            </value>
          </block>
        </value>
        <statement name="DO1">
          <block type="math_change" id="inc_tick_count">
            <field name="VAR" id="tick_count_var">tick_count</field>
            <value name="DELTA">
              <shadow type="math_number" id="inc_val"><field name="NUM">1</field></shadow>
            </value>
            <next>
              <block type="controls_if" id="check_strategy_step2">
                <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
                <value name="IF0">
                  <block type="logic_compare" id="is_odd_strat">
                    <field name="OP">EQ</field>
                    <value name="A">
                      <block type="variables_get" id="get_strat_step2"><field name="VAR" id="strategy_var">strategy_mode</field></block>
                    </value>
                    <value name="B">
                      <block type="text" id="odd_text_step2"><field name="TEXT">odd</field></block>
                    </value>
                  </block>
                </value>
                <statement name="DO0">
                  <block type="controls_if" id="check_timeout_odd">
                    <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
                    <value name="IF0">
                      <block type="logic_compare" id="check_5_ticks">
                        <field name="OP">LTE</field>
                        <value name="A">
                          <block type="variables_get" id="get_tick_count_odd"><field name="VAR" id="tick_count_var">tick_count</field></block>
                        </value>
                        <value name="B">
                          <block type="math_number" id="limit_5"><field name="NUM">5</field></block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO0">
                      <block type="controls_if" id="check_is_odd">
                        <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
                        <value name="IF0">
                          <block type="math_number_property" id="is_digit_odd">
                            <mutation xmlns="http://www.w3.org/1999/xhtml" divisor_input="false"></mutation>
                            <field name="PROPERTY">ODD</field>
                            <value name="NUMBER_TO_CHECK">
                              <shadow type="math_number" id="shadow_odd"><field name="NUM">0</field></shadow>
                              <block type="last_digit" id="digit_check_odd"></block>
                            </value>
                          </block>
                        </value>
                        <statement name="DO0">
                          <block type="math_change" id="inc_consecutive">
                            <field name="VAR" id="consecutive_var">consecutive_count</field>
                            <value name="DELTA">
                              <shadow type="math_number" id="inc_val_cons"><field name="NUM">1</field></shadow>
                            </value>
                            <next>
                              <block type="controls_if" id="check_2_consecutive">
                                <value name="IF0">
                                  <block type="logic_compare" id="gte_2">
                                    <field name="OP">GTE</field>
                                    <value name="A">
                                      <block type="variables_get" id="get_consecutive"><field name="VAR" id="consecutive_var">consecutive_count</field></block>
                                    </value>
                                    <value name="B">
                                      <block type="math_number" id="limit_2"><field name="NUM">2</field></block>
                                    </value>
                                  </block>
                                </value>
                                <statement name="DO0">
                                  <block type="variables_set" id="set_step3_odd">
                                    <field name="VAR" id="step_var">current_step</field>
                                    <value name="VALUE">
                                      <block type="math_number" id="step_3_val_odd"><field name="NUM">3</field></block>
                                    </value>
                                  </block>
                                </statement>
                              </block>
                            </next>
                          </block>
                        </statement>
                        <statement name="ELSE">
                          <block type="variables_set" id="reset_consecutive">
                            <field name="VAR" id="consecutive_var">consecutive_count</field>
                            <value name="VALUE">
                              <block type="math_number" id="zero_cons"><field name="NUM">0</field></block>
                            </value>
                          </block>
                        </statement>
                      </block>
                    </statement>
                    <statement name="ELSE">
                      <block type="variables_set" id="timeout_reset_odd">
                        <field name="VAR" id="step_var">current_step</field>
                        <value name="VALUE">
                          <block type="math_number" id="step_1_reset_odd"><field name="NUM">1</field></block>
                        </value>
                      </block>
                    </statement>
                  </block>
                </statement>
                <statement name="ELSE">
                  <block type="controls_if" id="check_timeout_even">
                    <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
                    <value name="IF0">
                      <block type="logic_compare" id="check_3_ticks">
                        <field name="OP">LTE</field>
                        <value name="A">
                          <block type="variables_get" id="get_tick_count_even"><field name="VAR" id="tick_count_var">tick_count</field></block>
                        </value>
                        <value name="B">
                          <block type="math_number" id="limit_3"><field name="NUM">3</field></block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO0">
                      <block type="controls_if" id="check_is_even">
                        <value name="IF0">
                          <block type="math_number_property" id="is_digit_even">
                            <mutation xmlns="http://www.w3.org/1999/xhtml" divisor_input="false"></mutation>
                            <field name="PROPERTY">EVEN</field>
                            <value name="NUMBER_TO_CHECK">
                              <shadow type="math_number" id="shadow_even"><field name="NUM">0</field></shadow>
                              <block type="last_digit" id="digit_check_even"></block>
                            </value>
                          </block>
                        </value>
                        <statement name="DO0">
                          <block type="controls_if" id="check_avoid_logic">
                            <value name="IF0">
                              <block type="logic_compare" id="compare_avoid">
                                <field name="OP">NEQ</field>
                                <value name="A">
                                  <block type="last_digit" id="ld_avoid"></block>
                                </value>
                                <value name="B">
                                  <block type="variables_get" id="get_avoid"><field name="VAR" id="avoid_var">bluebar digit to avoid (EVEN)</field></block>
                                </value>
                              </block>
                            </value>
                            <statement name="DO0">
                              <block type="variables_set" id="set_step3_even">
                                <field name="VAR" id="step_var">current_step</field>
                                <value name="VALUE">
                                  <block type="math_number" id="step_3_val_even"><field name="NUM">3</field></block>
                                </value>
                              </block>
                            </statement>
                          </block>
                        </statement>
                      </block>
                    </statement>
                    <statement name="ELSE">
                      <block type="variables_set" id="timeout_reset_even">
                        <field name="VAR" id="step_var">current_step</field>
                        <value name="VALUE">
                          <block type="math_number" id="step_1_reset_even"><field name="NUM">1</field></block>
                        </value>
                      </block>
                    </statement>
                  </block>
                </statement>
              </block>
            </next>
          </block>
        </statement>

        <statement name="ELSE">
          <block type="controls_if" id="final_buy_logic">
            <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
            <value name="IF0">
              <block type="logic_compare" id="is_odd_buy">
                <field name="OP">EQ</field>
                <value name="A">
                  <block type="variables_get" id="get_strat_buy"><field name="VAR" id="strategy_var">strategy_mode</field></block>
                </value>
                <value name="B">
                  <block type="text" id="odd_buy_text"><field name="TEXT">odd</field></block>
                </value>
              </block>
            </value>
            <statement name="DO0">
              <block type="purchase" id="buy_odd_final">
                <field name="PURCHASE_LIST">DIGITODD</field>
              </block>
            </statement>
            <statement name="ELSE">
              <block type="purchase" id="buy_even_final">
                <field name="PURCHASE_LIST">DIGITEVEN</field>
              </block>
            </statement>
          </block>
        </statement>
      </block>
    </statement>
  </block>

  <block type="after_purchase" id="after_purchase_root" deletable="false" x="800" y="60">
    <statement name="AFTERPURCHASE_STACK">
      <block type="controls_if" id="ap_if">
        <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
        <value name="IF0">
          <block type="contract_check_result" id="ap_check">
            <field name="CHECK_RESULT">win</field>
          </block>
        </value>
        <statement name="DO0">
          <block type="text_join" id="ap_win_text">
            <field name="VARIABLE" id="text_var">text</field>
            <statement name="STACK">
              <block type="text_statement" id="ap_win_ts1">
                <value name="TEXT">
                  <shadow type="text" id="ap_win_sh1"><field name="TEXT"></field></shadow>
                  <block type="text" id="ap_win_t1"><field name="TEXT">Ganhou: </field></block>
                </value>
                <next>
                  <block type="text_statement" id="ap_win_ts2">
                    <value name="TEXT">
                      <shadow type="text" id="ap_win_sh2"><field name="TEXT"></field></shadow>
                      <block type="read_details" id="ap_win_rd"><field name="DETAIL_INDEX">4</field></block>
                    </value>
                  </block>
                </next>
              </block>
            </statement>
            <next>
              <block type="notify" id="ap_win_notify">
                <field name="NOTIFICATION_TYPE">success</field>
                <field name="NOTIFICATION_SOUND">silent</field>
                <value name="MESSAGE">
                  <block type="variables_get" id="ap_win_get"><field name="VAR" id="text_var">text</field></block>
                </value>
                <next>
                  <block type="variables_set" id="ap_win_reset_stake">
                    <field name="VAR" id="stake_var">Stake</field>
                    <value name="VALUE">
                      <block type="variables_get" id="ap_win_get_stake2"><field name="VAR" id="stake2_var">stake 2</field></block>
                    </value>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </statement>
        <statement name="ELSE">
          <block type="text_join" id="ap_lose_text">
            <field name="VARIABLE" id="text1_var">text1</field>
            <statement name="STACK">
              <block type="text_statement" id="ap_lose_ts1">
                <value name="TEXT">
                  <shadow type="text" id="ap_lose_sh1"><field name="TEXT"></field></shadow>
                  <block type="text" id="ap_lose_t1"><field name="TEXT">Perdeu: </field></block>
                </value>
                <next>
                  <block type="text_statement" id="ap_lose_ts2">
                    <value name="TEXT">
                      <shadow type="text" id="ap_lose_sh2"><field name="TEXT"></field></shadow>
                      <block type="read_details" id="ap_lose_rd"><field name="DETAIL_INDEX">4</field></block>
                    </value>
                  </block>
                </next>
              </block>
            </statement>
            <next>
              <block type="notify" id="ap_lose_notify">
                <field name="NOTIFICATION_TYPE">warn</field>
                <field name="NOTIFICATION_SOUND">silent</field>
                <value name="MESSAGE">
                  <block type="variables_get" id="ap_lose_get"><field name="VAR" id="text1_var">text1</field></block>
                </value>
                <next>
                  <block type="variables_set" id="ap_lose_mart">
                    <field name="VAR" id="stake_var">Stake</field>
                    <value name="VALUE">
                      <block type="math_arithmetic" id="ap_lose_mart_math">
                        <field name="OP">MULTIPLY</field>
                        <value name="A">
                          <shadow type="math_number" id="ap_ma_sh"><field name="NUM">1</field></shadow>
                          <block type="variables_get" id="ap_lose_get_stake"><field name="VAR" id="stake_var">Stake</field></block>
                        </value>
                        <value name="B">
                          <shadow type="math_number" id="ap_mb_sh"><field name="NUM">2</field></shadow>
                          <block type="variables_get" id="ap_lose_get_mart"><field name="VAR" id="mart_var">product Martingale after loss</field></block>
                        </value>
                      </block>
                    </value>
                    <next>
                      <block type="controls_if" id="ap_lose_check_max">
                        <value name="IF0">
                          <block type="logic_compare" id="ap_lose_gt">
                            <field name="OP">GT</field>
                            <value name="A">
                              <block type="variables_get" id="ap_lose_get_stake_cmp"><field name="VAR" id="stake_var">Stake</field></block>
                            </value>
                            <value name="B">
                              <block type="variables_get" id="ap_lose_get_loss"><field name="VAR" id="loss_var">Loss</field></block>
                            </value>
                          </block>
                        </value>
                        <statement name="DO0">
                          <block type="variables_set" id="ap_lose_cap">
                            <field name="VAR" id="stake_var">Stake</field>
                            <value name="VALUE">
                              <block type="variables_get" id="ap_lose_get_stake2_cap"><field name="VAR" id="stake2_var">stake 2</field></block>
                            </value>
                          </block>
                        </statement>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </statement>
        <next>
          <block type="text_join" id="ap_tp_text">
            <field name="VARIABLE" id="text2_var">text2</field>
            <statement name="STACK">
              <block type="text_statement" id="ap_tp_ts1">
                <value name="TEXT">
                  <shadow type="text" id="ap_tp_sh1"><field name="TEXT"></field></shadow>
                  <block type="text" id="ap_tp_t1"><field name="TEXT">Total Profit: </field></block>
                </value>
                <next>
